# Twilio
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# System ops alerts phone number (used by alerts.system_phone_number in config)
SYSTEM_PHONE_NUMBER=+48XXXXXXXXX

# PostgreSQL connection string
DATABASE_URL=postgresql://sentinel:your_password@localhost:5432/sentinel

# Initial user setup (used by scripts/migrate_sqlite_to_pg.py and scripts/create_initial_user.py)
ALERT_PHONE_NUMBER=+48XXXXXXXXX
ALERT_USER_NAME=Your Name

# Anthropic (Claude Haiku for classification)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Telegram (optional -- for channel monitoring)
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890
