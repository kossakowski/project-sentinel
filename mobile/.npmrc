# @testing-library/react-native@13 declares react-test-renderer as a required peer,
# but RNTL 13 on React 19 uses React's own concurrent renderer and does NOT need
# react-test-renderer (the inbox spec explicitly says not to add it). npm 11's
# strict peer resolution would otherwise try to pull react-test-renderer@19.2.x,
# which conflicts with the SDK-54 React 19.1.0 pin. legacy-peer-deps lets the
# pinned, SDK-aligned tree install cleanly.
legacy-peer-deps=true
